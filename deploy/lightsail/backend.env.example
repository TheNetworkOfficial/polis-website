NODE_ENV=production
PORT=3000

# Public site URL for share links and OAuth relay pages. This must match the
# exact canonical host used in shared URLs. For Polis production, use the apex
# domain instead of the www host.
PUBLIC_WEB_BASE_URL=https://polisapp.io

# Existing app backend that serves the share-card API and social OAuth callbacks.
VIDEO_BACKEND_BASE_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com/prod

# Required only if you run the full legacy website backend (src/server.js)
# instead of the lightweight public server (src/publicServer.js).
# SESSION_SECRET=replace-me-with-a-long-random-secret
# DB_SQLITE_PATH=/var/lib/polis-website/site.sqlite

# Optional: use a custom frontend build location. Leave unset if you deploy to
# /var/www/polis-website/frontend/dist.
# FRONTEND_DIST_PATH=/var/www/polis-website/frontend/dist

# App-link metadata served from /.well-known/*
ANDROID_APP_PACKAGE=com.luxcorp.polis
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:EE:FF
IOS_APP_ID=TEAMID.com.luxcorp.polis

# Optional store URLs
# IOS_APP_STORE_ID=1234567890
# IOS_APP_STORE_URL=https://apps.apple.com/us/app/id1234567890
# ANDROID_APP_STORE_URL=https://play.google.com/store/apps/details?id=com.luxcorp.polis
