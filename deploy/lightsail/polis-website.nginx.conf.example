server {
    listen 80;
    server_name example.com www.example.com;

    root /var/www/polis-website/frontend/dist;
    index index.html;

    # Share pages, OAuth relay, app-link metadata, and any website API routes.
    location ^~ /.well-known/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /oauth/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /posts/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Dynamic Polis web-app routes need the backend shell so direct links and
    # nested browser-app pages hydrate with the same route metadata as the app.
    location ~ ^/(account-deletion-requested|achievements|admin|auth|auto-candidates|calendar-return|candidate|candidate-dashboard|candidates|coalitions|create|create-tab|cta-invite|discover|election-day|events|feed|manage-events|messages|missions|officials|onboarding|profile|profile-tab|questions|search|settings|social-return|topics)(/.*)?$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /404.html;
    }
}
